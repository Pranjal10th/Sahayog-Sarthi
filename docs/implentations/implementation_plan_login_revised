## 5. Protected Routes Strategy (Role-Based Guards)

To protect sensitive routes, a Higher-Order Component (HOC) `withAuth` validates user permissions against three roles: `customer`, `worker`, and `admin`.

```javascript
// frontend/src/components/withAuth.js
import { useEffect, useState } from 'react';
import { useRouter } from 'next/router';

export default function withAuth(Component, allowedRoles = []) {
  return function AuthenticatedComponent(props) {
    const router = useRouter();
    const [verified, setVerified] = useState(false);

    useEffect(() => {
      const token = localStorage.getItem('token');
      const role = localStorage.getItem('role');

      if (!token) {
        router.replace('/auth/login');
      } else if (allowedRoles.length > 0 && !allowedRoles.includes(role)) {
        // Role mismatch - redirect to their default dashboards
        if (role === 'worker') {
          const workerId = JSON.parse(localStorage.getItem('user'))?._id;
          router.replace(`/workers/${workerId}/dashboard`);
        } else if (role === 'admin') {
          router.replace('/admin/overview');
        } else {
          router.replace('/');
        }
      } else {
        setVerified(true);
      }
    }, [router]);

    if (!verified) return null; // Prevent UI flashing before auth verification
    return <Component {...props} />;
  };
}
```

### Protection Mappings:
*   **Worker Dashboard** (`/src/pages/workers/[id]/dashboard.js`) ➔ protected for `['worker']`
*   **Admin Dashboard** (`/src/pages/admin/overview.js`) ➔ protected for `['admin']`
*   **Booking History** (`/src/pages/bookings/history.js`) ➔ protected for `['customer']`

