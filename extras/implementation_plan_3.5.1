## Implementation Strategy

### 1. Persistence Layer Updates

#### `MongoUserRepository.js`
- Create a read-only MongoDB repository wrapper for the `User` model:
  ```javascript
  import User from '../../../../../models/User.js';

  export default class MongoUserRepository {
    async countDocuments(filters = {}) {
      return await User.countDocuments(filters);
    }
  }
  ```

#### `MongoBookingRepository.js`
- Add a helper to retrieve active live bookings:
  ```javascript
  async findLiveBookings() {
    return await Booking.find({
      status: { $in: ['pending', 'accepted', 'in_progress'] }
    }).sort({ createdAt: -1 });
  }
  ```

#### `MongoPaymentRepository.js`
- Add a helper to retrieve paid payments:
  ```javascript
  async findPaidPayments() {
    return await Payment.find({ status: 'paid' });
  }
  ```

### 2. Application Logic Layer (Use Cases)

#### `GetAdminOverviewUseCase.js`
- Create a clean orchestration class mapping data queries to respective repositories and calculating the 15% platform split commission:
  ```javascript
  export default class GetAdminOverviewUseCase {
    constructor(workerRepository, bookingRepository, paymentRepository, userRepository) {
      this.workerRepository = workerRepository;
      this.bookingRepository = bookingRepository;
      this.paymentRepository = paymentRepository;
      this.userRepository = userRepository;
    }

    async execute() {
      const totalUsers = await this.userRepository.countDocuments({});
      const activeWorkers = await this.workerRepository.countDocuments({ kycStatus: 'approved', isAvailable: true });
      const paymentsPaid = await this.paymentRepository.findPaidPayments();
      const platformRevenue = paymentsPaid.reduce((sum, current) => sum + (current.amount * 0.15), 0);
      const pendingWorkers = await this.workerRepository.findWithFilters({ kycStatus: 'pending' });
      const liveBookings = await this.bookingRepository.findLiveBookings();

      return {
        metrics: {
          totalUsers,
          activeWorkers,
          platformRevenue: parseFloat(platformRevenue.toFixed(2))
        },
        pendingWorkers,
        liveBookings
      };
    }
  }
  ```

### 3. Controller and Route Wiring

#### `container.js`
- Wire dependencies and instantiate the use case:
  ```javascript
  import MongoUserRepository from '../persistence/repositories/MongoUserRepository.js';
  import GetAdminOverviewUseCase from '../../application/use-cases/GetAdminOverviewUseCase.js';

  const userRepository = new MongoUserRepository();
  export const getAdminOverviewUseCase = new GetAdminOverviewUseCase(
    workerRepository,
    bookingRepository,
    paymentRepository,
    userRepository
  );
  ```

#### `WorkerController.js`
- Add the `getAdminOverview` handler method:
  ```javascript
  import { ..., getAdminOverviewUseCase } from '../../../infrastructure/di/container.js';

  export const getAdminOverview = async (req, res) => {
    try {
      const data = await getAdminOverviewUseCase.execute();
      return res.status(200).json({
        success: true,
        ...data
      });
    } catch (err) {
      return res.status(500).json({ success: false, error: err.message });
    }
  };
  ```

#### `workerRoutes.js`
- Clean up imports and swap the endpoint:
  ```javascript
  // REMOVE: import { getAdminOverviewHub } from '../../../../../controllers/workerController.js';
  // ADD: getAdminOverview to imports from '../controllers/WorkerController.js';
  
  router.get('/admin/overview', protect, getAdminOverview);
  ```

