    *   `src/modules/worker/application/use-cases/UnblockWorkerUseCase.js`
    *   `src/modules/worker/application/use-cases/UpdateWorkerAvailabilityUseCase.js`
    *   `src/modules/worker/application/use-cases/FindNearbyWorkersUseCase.js`
    *   `src/modules/worker/application/use-cases/GetWorkerDashboardUseCase.js`
*   `Persistence schema`: `src/modules/worker/infrastructure/persistence/schemas/WorkerSchema.js`
*   `Persistence mapper`: `src/modules/worker/infrastructure/persistence/mappers/WorkerMapper.js`
*   `Mongo Repository adapter`: `src/modules/worker/infrastructure/persistence/repositories/MongoWorkerRepository.js`
*   `Clean HTTP Controller`: `src/modules/worker/interfaces/http/controllers/WorkerController.js`
*   `Clean HTTP Router`: `src/modules/worker/interfaces/http/routes/workerRoutes.js`

