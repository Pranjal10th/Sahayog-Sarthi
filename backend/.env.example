# =============================================
# Sahayog Sarthi Backend – Environment Variables
# =============================================
# Copy this file to .env and fill in real values.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGO_URI=mongodb://localhost:27017/sahayog_sarthi

# --- Authentication ---
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=7d

# --- Redis (Caching & OTP Store) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
ENABLE_TELEGRAM_BOT=false

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Platform Business Logic ---
PLATFORM_COMMISSION=0.15

# --- SMS Gateway (MSG91) ---
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
